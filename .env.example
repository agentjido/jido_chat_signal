# Copy this file to `.env` and fill in real values.
# `test/test_helper.exs` loads `.env` with Dotenvy before tests run.

# Set true to enable tests tagged `:live`.
RUN_LIVE_SIGNAL_TESTS=false

# `cli` uses one-shot `signal-cli send`; `json_rpc` uses `signal-cli daemon --http`.
SIGNAL_TRANSPORT=cli

# signal-cli HTTP JSON-RPC endpoint.
# Start one with:
# signal-cli -a +15555550100 daemon --http=127.0.0.1:8080
SIGNAL_RPC_ENDPOINT=http://127.0.0.1:8080/api/v1/rpc

# Account/phone number registered or linked in signal-cli.
# Required when the daemon runs in multi-account mode.
SIGNAL_ACCOUNT=

# Recipient phone number, UUID, or `group:BASE64_GROUP_ID`.
SIGNAL_TEST_RECIPIENT=

# Suggested receive settings for adapter-owned polling ingress.
SIGNAL_INGRESS_MODE=rpc_polling
SIGNAL_RECEIVE_TIMEOUT_S=1
SIGNAL_RECEIVE_MAX_MESSAGES=10
